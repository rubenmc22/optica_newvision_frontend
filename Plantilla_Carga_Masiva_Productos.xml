 <Worksheet ss:Name="Instrucciones">
  <Table>
   <Column ss:Width="220"/>
   <Column ss:Width="520"/>
   <Row>
    <Cell ss:StyleID="sTitle"><Data ss:Type="String">Plantilla de carga masiva de productos</Data></Cell>
    <Cell ss:StyleID="sTitle"><Data ss:Type="String">Optica New Vision</Data></Cell>
   </Row>
   <Row>
    <Cell ss:StyleID="sHeader"><Data ss:Type="String">Tema</Data></Cell>
    <Cell ss:StyleID="sHeader"><Data ss:Type="String">Indicacion</Data></Cell>
   </Row>
   <Row><Cell><Data ss:Type="String">Uso general</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">Use una fila por producto. Puede cargar todo desde la hoja Plantilla General o trabajar por categoria en las hojas separadas.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">Categorias validas</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">Cristales, Monturas, Lentes de contacto, Liquidos, Estuches, Accesorios.</Data></Cell></Row>
    <Row><Cell><Data ss:Type="String">Campos comunes obligatorios</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">categoria, stock, precio_venta, aplica_iva, requiere_formula y activo.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">Booleanos</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">Llenar solo con TRUE o FALSE.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">Precio</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">precio_venta es el precio final comercial. Si aplica_iva = TRUE, debe venir con IVA incluido. Si aplica_iva = FALSE, va sin IVA.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">Nombre</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">nombre_personalizado es opcional. Si queda vacio, el sistema genera el nombre automaticamente.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">Descripcion</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">descripcion_personalizada es opcional. Si queda vacia, el sistema genera una descripcion base.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">Nombre automatico no cristal</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">Para Monturas, Lentes de contacto, Liquidos, Estuches y Accesorios: CATEGORIA MARCA MODELO MATERIAL. Solo usa las partes que apliquen.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">Nombre automatico cristal</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">Para Cristales: tipo_cristal + presentacion + material + tratamientos + rango_formula.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">Tratamientos</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">Si un cristal tiene varios tratamientos, se separan con barra vertical. Ejemplo: Antirreflejo|Filtro azul|Fotocromatico.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">Material otro</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">material_otro solo aplica a Cristales cuando material = Otro.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">Costo laboratorio</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">costo_laboratorio solo aplica a Cristales.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">Imagen</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">Esta plantilla no incluye carga de imagen. Si no se carga imagen, el sistema deja la imagen generica por defecto.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">Campos vacios</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">En cada hoja por categoria deje en blanco los campos que no apliquen. No invente valores para completar.</Data></Cell></Row>
    <Row><Cell><Data ss:Type="String">requiere_item_padre</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">Se omite de esta plantilla. Para la carga masiva se asumira FALSE por defecto salvo que luego definamos una regla especial de importacion.</Data></Cell></Row>
  </Table>
 </Worksheet>
 <Worksheet ss:Name="Diccionario">
  <Table>
   <Column ss:Width="170"/>
   <Column ss:Width="90"/>
   <Column ss:Width="220"/>
   <Column ss:Width="380"/>
   <Row>
    <Cell ss:StyleID="sHeader"><Data ss:Type="String">Campo</Data></Cell>
    <Cell ss:StyleID="sHeader"><Data ss:Type="String">Tipo</Data></Cell>
    <Cell ss:StyleID="sHeader"><Data ss:Type="String">Aplica a</Data></Cell>
    <Cell ss:StyleID="sHeader"><Data ss:Type="String">Regla</Data></Cell>
   </Row>
   <Row><Cell><Data ss:Type="String">categoria</Data></Cell><Cell><Data ss:Type="String">Texto</Data></Cell><Cell ss:StyleID="sRequired"><Data ss:Type="String">Todas</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">Debe ser una categoria comercial valida.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">nombre_personalizado</Data></Cell><Cell><Data ss:Type="String">Texto</Data></Cell><Cell ss:StyleID="sOptional"><Data ss:Type="String">Todas</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">Si queda vacio, el sistema lo genera.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">descripcion_personalizada</Data></Cell><Cell><Data ss:Type="String">Texto</Data></Cell><Cell ss:StyleID="sOptional"><Data ss:Type="String">Todas</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">Si queda vacia, el sistema genera descripcion base.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">stock</Data></Cell><Cell><Data ss:Type="String">Numero</Data></Cell><Cell ss:StyleID="sRequired"><Data ss:Type="String">Todas</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">Cantidad disponible en inventario.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">precio_venta</Data></Cell><Cell><Data ss:Type="String">Numero</Data></Cell><Cell ss:StyleID="sRequired"><Data ss:Type="String">Todas</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">Precio final comercial. Si aplica IVA debe venir con IVA.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">aplica_iva</Data></Cell><Cell><Data ss:Type="String">Booleano</Data></Cell><Cell ss:StyleID="sRequired"><Data ss:Type="String">Todas</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">TRUE o FALSE.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">requiere_formula</Data></Cell><Cell><Data ss:Type="String">Booleano</Data></Cell><Cell ss:StyleID="sRequired"><Data ss:Type="String">Todas</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">TRUE si el producto requiere formula medica.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">activo</Data></Cell><Cell><Data ss:Type="String">Booleano</Data></Cell><Cell ss:StyleID="sRequired"><Data ss:Type="String">Todas</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">TRUE para vender, FALSE para dejar inactivo.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">marca</Data></Cell><Cell><Data ss:Type="String">Texto</Data></Cell><Cell ss:StyleID="sOptional"><Data ss:Type="String">Todas</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">En Cristales es opcional. En las demas categorias conviene llenarlo para nombre y busqueda.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">modelo</Data></Cell><Cell><Data ss:Type="String">Texto</Data></Cell><Cell ss:StyleID="sOptional"><Data ss:Type="String">Monturas, Liquidos, Estuches, Accesorios</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">Tambien se usa como nombre base en la construccion automatica.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">color</Data></Cell><Cell><Data ss:Type="String">Texto</Data></Cell><Cell ss:StyleID="sOptional"><Data ss:Type="String">Monturas, Lentes de contacto, Accesorios, Cristales</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">En Cristales normalmente puede ir vacio.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">material</Data></Cell><Cell><Data ss:Type="String">Texto</Data></Cell><Cell ss:StyleID="sOptional"><Data ss:Type="String">Cristales, Monturas, Lentes de contacto, Estuches, Accesorios</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">En Liquidos no se usa para el contrato actual.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">material_otro</Data></Cell><Cell><Data ss:Type="String">Texto</Data></Cell><Cell ss:StyleID="sOptional"><Data ss:Type="String">Cristales</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">Llenar solo si material = Otro.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">proveedor</Data></Cell><Cell><Data ss:Type="String">Texto</Data></Cell><Cell ss:StyleID="sOptional"><Data ss:Type="String">Todas</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">Se recomienda llenarlo para trazabilidad y compras.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">tipo_cristal</Data></Cell><Cell><Data ss:Type="String">Texto</Data></Cell><Cell ss:StyleID="sRequired"><Data ss:Type="String">Cristales</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">Ejemplo: Monofocal vision sencilla, Bifocal, Progresivo.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">presentacion</Data></Cell><Cell><Data ss:Type="String">Texto</Data></Cell><Cell ss:StyleID="sOptional"><Data ss:Type="String">Cristales</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">Si la familia usa selector cerrado, trate de usar Stock o Semi-terminado.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">tratamientos</Data></Cell><Cell><Data ss:Type="String">Texto</Data></Cell><Cell ss:StyleID="sOptional"><Data ss:Type="String">Cristales</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">Separar multiples valores con |.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">rango_formula</Data></Cell><Cell><Data ss:Type="String">Texto</Data></Cell><Cell ss:StyleID="sOptional"><Data ss:Type="String">Cristales, Lentes de contacto</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">Ejemplo: Esf. +4.00 a -6.00.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">costo_laboratorio</Data></Cell><Cell><Data ss:Type="String">Numero</Data></Cell><Cell ss:StyleID="sOptional"><Data ss:Type="String">Cristales</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">Costo interno o del laboratorio.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">tipo_lente_contacto</Data></Cell><Cell><Data ss:Type="String">Texto</Data></Cell><Cell ss:StyleID="sRequired"><Data ss:Type="String">Lentes de contacto</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">Ejemplo: Esferico, Torico, Multifocal.</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">notas_importacion</Data></Cell><Cell><Data ss:Type="String">Texto</Data></Cell><Cell ss:StyleID="sOptional"><Data ss:Type="String">Todas</Data></Cell><Cell ss:StyleID="sNote"><Data ss:Type="String">Solo para comentarios del cliente o del equipo de carga.</Data></Cell></Row>
  </Table>
 </Worksheet>
